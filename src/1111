          {/* أزرار التحكم */}
          <div className="flex gap-3 pt-4 border-t">
            <button onClick={handleSave} disabled={loading} className="flex-1 bg-indigo-600 text-white py-3 rounded-xl font-bold hover:bg-indigo-700 flex items-center justify-center gap-2">
              {loading ? <Loader2 className="animate-spin" size={18} /> : <><Save size={18} /> حفظ التذكرة</>}
            </button>
            <button onClick={onClose} className="flex-1 bg-slate-100 text-slate-600 py-3 rounded-xl font-bold hover:bg-slate-200">إلغاء</button>
          </div>
        </div>
      </div>
    </div>
  );
}
import React, { useState, useEffect, useCallback } from 'react';
import { 
  ArrowRightLeft, Search, Plus, Check, X, Clock, Eye,
  Package, Truck, FileText, Filter, RefreshCw, AlertCircle,
  UserCheck, UserX, Loader2, ChevronDown, Building, MapPin
} from 'lucide-react';
import { useAuth } from '../../contexts/AuthContext';
import { useSettings } from '../../contexts/SettingsContext';
import { 
  collection, doc, getDocs, getDoc, addDoc, updateDoc, deleteDoc,
  query, where, orderBy, limit, startAfter, serverTimestamp,
  runTransaction, writeBatch, increment, onSnapshot
} from 'firebase/firestore';
import { db } from '../../services/firebase';
import { formatDate, showSuccess, showError, showConfirm, logUserActivity } from '../../utils/helpers';
import { ConfirmModal } from '../common/ConfirmModal';
import { StatusBadge } from '../common/StatusBadge';

export function TransferManager() {
  const { user } = useAuth();
  const { warehouses, warehouseMap } = useSettings();

  // حالات البيانات
  const [transfers, setTransfers] = useState([]);
  const [filteredTransfers, setFilteredTransfers] = useState([]);
  const [loading, setLoading] = useState(true);
  const [lastDoc, setLastDoc] = useState(null);
  const [hasMore, setHasMore] = useState(true);
  const [inventory, setInventory] = useState([]);

  // حالات البحث والتصفية
  const [searchTerm, setSearchTerm] = useState('');
  const [statusFilter, setStatusFilter] = useState('all');
  const [warehouseFilter, setWarehouseFilter] = useState('all');
  const [dateRange, setDateRange] = useState({ from: '', to: '' });

  // حالات النماذج
  const [showAddModal, setShowAddModal] = useState(false);
  const [selectedProduct, setSelectedProduct] = useState(null);
  const [productSearch, setProductSearch] = useState('');
  const [requestQty, setRequestQty] = useState(1);
  const [toWarehouse, setToWarehouse] = useState('');
  const [requestNotes, setRequestNotes] = useState('');
  const [isSubmitting, setIsSubmitting] = useState(false);

  // حالات الموافقة والرفض
  const [selectedTransfer, setSelectedTransfer] = useState(null);
  const [rejectReason, setRejectReason] = useState('');
  const [showApproveModal, setShowApproveModal] = useState(false);
  const [showRejectModal, setShowRejectModal] = useState(false);
  const [processingId, setProcessingId] = useState(null);

  // إحصائيات
  const [stats, setStats] = useState({
    pending: 0,
    approved: 0,
    rejected: 0,
    totalItems: 0
  });

  const currentWarehouseId = user?.assignedWarehouseId || 'main';
  const canApprove = user?.role === 'admin' || user?.role === 'main_warehouse_manager' || user?.permissions?.approveTransfers;

  // تحميل البيانات في الوقت الفعلي
  useEffect(() => {
    // الاستماع للتغييرات في التحويلات
    let transfersQuery = collection(db, 'transfers');
    
    if (!user?.permissions?.viewAllWarehouses) {
      transfersQuery = query(transfersQuery, 
        where('fromWarehouseId', '==', currentWarehouseId),
        orderBy('createdAt', 'desc')
      );
    } else {
      transfersQuery = query(transfersQuery, orderBy('createdAt', 'desc'));
    }

    const unsubTransfers = onSnapshot(transfersQuery, (snap) => {
      const data = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      setTransfers(data);
      
      // تحديث الإحصائيات
      const pending = data.filter(t => t.status === 'pending').length;
      const approved = data.filter(t => t.status === 'approved').length;
      const rejected = data.filter(t => t.status === 'rejected').length;
      const totalItems = data.reduce((sum, t) => sum + (t.requestedQty || 0), 0);
      setStats({ pending, approved, rejected, totalItems });
      
      setLoading(false);
    }, (error) => {
      console.error('Error loading transfers:', error);
      setLoading(false);
    });

    // تحميل مخزون المستخدم الحالي
    const invQuery = query(
      collection(db, 'inventory'),
      where('warehouseId', '==', currentWarehouseId),
      where('isDeleted', '==', false)
    );
    
    const unsubInventory = onSnapshot(invQuery, (snap) => {
      setInventory(snap.docs.map(d => ({ id: d.id, ...d.data() })));
    });

    return () => {
      unsubTransfers();
      unsubInventory();
    };
  }, [currentWarehouseId, user]);

  // فلترة التحويلات
  useEffect(() => {
    let filtered = [...transfers];
    
    if (searchTerm) {
      const term = searchTerm.toLowerCase();
      filtered = filtered.filter(t => 
        t.itemName?.toLowerCase().includes(term) ||
        t.serialNumber?.toLowerCase().includes(term) ||
        t.requestedBy?.toLowerCase().includes(term)
      );
    }
    
    if (statusFilter !== 'all') {
      filtered = filtered.filter(t => t.status === statusFilter);
    }
    
    if (warehouseFilter !== 'all') {
      filtered = filtered.filter(t => 
        t.fromWarehouseId === warehouseFilter || 
        t.toWarehouseId === warehouseFilter
      );
    }
    
    if (dateRange.from) {
      const fromDate = new Date(dateRange.from);
      fromDate.setHours(0, 0, 0, 0);
      filtered = filtered.filter(t => {
        const date = t.createdAt?.toDate?.() || new Date(t.createdAt);
        return date >= fromDate;
      });
    }
    
    if (dateRange.to) {
      const toDate = new Date(dateRange.to);
      toDate.setHours(23, 59, 59, 999);
      filtered = filtered.filter(t => {
        const date = t.createdAt?.toDate?.() || new Date(t.createdAt);
        return date <= toDate;
      });
    }
    
    setFilteredTransfers(filtered);
  }, [transfers, searchTerm, statusFilter, warehouseFilter, dateRange]);

  // البحث عن منتج
  const handleProductSearch = async (e) => {
    e.preventDefault();
    if (!productSearch.trim()) return;

    const normalizedSearch = productSearch.toLowerCase().trim();
    const found = inventory.find(item => 
      item.serialNumber?.toLowerCase().includes(normalizedSearch) ||
      item.name?.toLowerCase().includes(normalizedSearch)
    );

    if (found) {
      setSelectedProduct(found);
      setProductSearch('');
    } else {
      showError("المنتج غير موجود في مخزنك");
    }
  };

  // إنشاء طلب تحويل جديد
  const handleCreateTransfer = async () => {
    if (!selectedProduct) {
      showError("الرجاء اختيار منتج");
      return;
    }
    if (!toWarehouse) {
      showError("الرجاء اختيار المخزن المرسل إليه");
      return;
    }
    if (requestQty <= 0) {
      showError("الكمية غير صالحة");
      return;
    }
    if (requestQty > selectedProduct.quantity) {
      showError(`الكمية المطلوبة (${requestQty}) أكبر من المتاح (${selectedProduct.quantity})`);
      return;
    }
    
    setIsSubmitting(true);
    try {
      await addDoc(collection(db, 'transfers'), {
        serialNumber: selectedProduct.serialNumber,
        itemName: selectedProduct.name,
        requestedQty: Number(requestQty),
        fromWarehouseId: currentWarehouseId,
        fromWarehouseName: warehouseMap[currentWarehouseId] || currentWarehouseId,
        toWarehouseId: toWarehouse,
        toWarehouseName: warehouseMap[toWarehouse] || toWarehouse,
        status: 'pending',
        requestedBy: user?.name || user?.email,
        requestedById: user?.id,
        requestedByRole: user?.role,
        notes: requestNotes,
        createdAt: serverTimestamp()
      });
      
      await logUserActivity(user, 'طلب تحويل مخزني', 
        `طلب تحويل ${requestQty} قطعة من ${selectedProduct.name} إلى ${warehouseMap[toWarehouse] || toWarehouse}`
      );
      
      showSuccess("تم إرسال طلب التحويل بنجاح");
      
      // إعادة تعيين النموذج
      setSelectedProduct(null);
      setProductSearch('');
      setRequestQty(1);
      setToWarehouse('');
      setRequestNotes('');
      setShowAddModal(false);
      
    } catch (error) {
      console.error('Error creating transfer:', error);
      showError("فشل إرسال الطلب: " + error.message);
    } finally {
      setIsSubmitting(false);
    }
  };

  // الموافقة على طلب تحويل
  const handleApprove = async (transfer) => {
    setProcessingId(transfer.id);
    try {
      await runTransaction(db, async (transaction) => {
        // 1. جلب المنتج من المخزن المصدر
        const fromQuery = query(
          collection(db, 'inventory'),
          where('serialNumber', '==', transfer.serialNumber),
          where('warehouseId', '==', transfer.fromWarehouseId),
          where('isDeleted', '==', false)
        );
        const fromSnap = await getDocs(fromQuery);
        
        if (fromSnap.empty) {
          throw new Error("المنتج غير موجود في المخزن المصدر!");
        }
        
        const fromItem = fromSnap.docs[0];
        const fromData = fromItem.data();
        const currentQty = fromData.quantity || 0;
        
        if (currentQty < transfer.requestedQty) {
          throw new Error(`الكمية غير كافية! المتاح: ${currentQty}, المطلوب: ${transfer.requestedQty}`);
        }
        
        // 2. خصم الكمية من المخزن المصدر
        transaction.update(fromItem.ref, {
          quantity: increment(-transfer.requestedQty),
          updatedAt: serverTimestamp()
        });
        
        // 3. إضافة الكمية للمخزن الهدف
        const toQuery = query(
          collection(db, 'inventory'),
          where('serialNumber', '==', transfer.serialNumber),
          where('warehouseId', '==', transfer.toWarehouseId),
          where('isDeleted', '==', false)
        );
        const toSnap = await getDocs(toQuery);
        
        if (toSnap.empty) {
          // إنشاء منتج جديد في المخزن الهدف
          const newRef = doc(collection(db, 'inventory'));
          transaction.set(newRef, {
            ...fromData,
            id: newRef.id,
            warehouseId: transfer.toWarehouseId,
            quantity: transfer.requestedQty,
            createdAt: serverTimestamp(),
            updatedAt: serverTimestamp()
          });
        } else {
          // تحديث الكمية في المخزن الهدف
          const toItem = toSnap.docs[0];
          transaction.update(toItem.ref, {
            quantity: increment(transfer.requestedQty),
            updatedAt: serverTimestamp()
          });
        }
        
        // 4. تحديث حالة الطلب
        const transferRef = doc(db, 'transfers', transfer.id);
        transaction.update(transferRef, {
          status: 'approved',
          processedAt: serverTimestamp(),
          processedBy: user?.name || user?.email,
          processedById: user?.id,
          processedByRole: user?.role
        });
      });
      
      await logUserActivity(user, 'موافقة على تحويل مخزني',
        `تمت الموافقة على تحويل ${transfer.requestedQty} قطعة من ${transfer.itemName} إلى ${warehouseMap[transfer.toWarehouseId]}`
      );
      
      showSuccess("تمت الموافقة على التحويل بنجاح");
      
    } catch (error) {
      console.error('Error approving transfer:', error);
      showError(error.message || "فشل الموافقة على التحويل");
    } finally {
      setProcessingId(null);
      setShowApproveModal(false);
      setSelectedTransfer(null);
    }
  };

  // رفض طلب تحويل
  const handleReject = async () => {
    if (!selectedTransfer) return;
    if (!rejectReason.trim()) {
      showError("الرجاء كتابة سبب الرفض");
      return;
    }
    
    setProcessingId(selectedTransfer.id);
    try {
      const transferRef = doc(db, 'transfers', selectedTransfer.id);
      await updateDoc(transferRef, {
        status: 'rejected',
        rejectReason: rejectReason,
        processedAt: serverTimestamp(),
        processedBy: user?.name || user?.email,
        processedById: user?.id
      });
      
      await logUserActivity(user, 'رفض تحويل مخزني',
        `رفض طلب تحويل ${selectedTransfer.requestedQty} قطعة من ${selectedTransfer.itemName} إلى ${warehouseMap[selectedTransfer.toWarehouseId]} بسبب: ${rejectReason}`
      );
      
      showSuccess("تم رفض الطلب بنجاح");
      
      setShowRejectModal(false);
      setSelectedTransfer(null);
      setRejectReason('');
      
    } catch (error) {
      console.error('Error rejecting transfer:', error);
      showError("فشل رفض الطلب");
    } finally {
      setProcessingId(null);
    }
  };

  // حذف طلب (للمدير فقط)
  const handleDeleteTransfer = async (transfer) => {
    const confirmed = await showConfirm(
      'تأكيد الحذف',
      `هل أنت متأكد من حذف طلب تحويل ${transfer.itemName}؟`,
      'warning'
    );
    
    if (!confirmed) return;
    
    setProcessingId(transfer.id);
    try {
      await deleteDoc(doc(db, 'transfers', transfer.id));
      showSuccess("تم حذف الطلب بنجاح");
    } catch (error) {
      console.error('Error deleting transfer:', error);
      showError("فشل حذف الطلب");
    } finally {
      setProcessingId(null);
    }
  };

  const pendingRequests = filteredTransfers.filter(t => t.status === 'pending');
  const processedRequests = filteredTransfers.filter(t => t.status !== 'pending');
  const uniqueWarehouses = [...new Set(transfers.map(t => t.fromWarehouseId).concat(transfers.map(t => t.toWarehouseId)))];

  return (
    <div className="space-y-6 text-right" dir="rtl">
      
      {/* Modal إنشاء طلب تحويل */}
      {showAddModal && (
        <div className="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
          <div className="bg-white dark:bg-slate-800 rounded-2xl p-6 w-full max-w-lg shadow-2xl">
            <div className="flex justify-between items-center mb-4">
              <h3 className="font-black text-xl text-slate-800 dark:text-white">طلب تحويل جديد</h3>
              <button onClick={() => setShowAddModal(false)} className="p-1 hover:bg-slate-100 rounded">
                <X size={20} />
              </button>
            </div>

            {!selectedProduct ? (
              <div>
                <label className="block text-xs font-bold text-slate-500 mb-1">ابحث عن منتج</label>
                <form onSubmit={handleProductSearch} className="flex gap-2">
                  <input
                    className="flex-1 border border-slate-200 dark:border-slate-700 p-3 rounded-xl focus:border-indigo-500 outline-none"
                    placeholder="الاسم أو السيريال"
                    value={productSearch}
                    onChange={e => setProductSearch(e.target.value)}
                  />
                  <button type="submit" className="bg-indigo-600 text-white px-4 rounded-xl hover:bg-indigo-700">
                    <Search size={18} />
                  </button>
                </form>
              </div>
            ) : (
              <div className="space-y-4">
                <div className="bg-indigo-50 dark:bg-indigo-900/30 p-4 rounded-xl">
                  <div className="flex justify-between items-start">
                    <div>
                      <p className="font-bold text-indigo-900 dark:text-indigo-300">{selectedProduct.name}</p>
                      <p className="text-xs font-mono text-indigo-700 dark:text-indigo-400">{selectedProduct.serialNumber}</p>
                    </div>
                    <button onClick={() => setSelectedProduct(null)} className="text-indigo-500 hover:text-indigo-700">
                      <X size={16} />
                    </button>
                  </div>
                  <div className="mt-2 flex justify-between text-sm">
                    <span className="text-indigo-700 dark:text-indigo-400">المتوفر:</span>
                    <span className="font-bold text-indigo-900 dark:text-indigo-300">{selectedProduct.quantity}</span>
                  </div>
                  <div className="flex justify-between text-sm">
                    <span className="text-indigo-700 dark:text-indigo-400">السعر:</span>
                    <span className="font-bold text-indigo-900 dark:text-indigo-300">{selectedProduct.price} ج</span>
                  </div>
                </div>

                <div>
                  <label className="block text-xs font-bold text-slate-500 mb-1">الكمية المطلوبة</label>
                  <input
                    type="number"
                    min="1"
                    max={selectedProduct.quantity}
                    className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl text-center"
                    value={requestQty}
                    onChange={e => setRequestQty(Math.min(Number(e.target.value), selectedProduct.quantity) || 1)}
                  />
                </div>

                <div>
                  <label className="block text-xs font-bold text-slate-500 mb-1">إلى مخزن</label>
                  <select
                    className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl bg-white dark:bg-slate-900"
                    value={toWarehouse}
                    onChange={e => setToWarehouse(e.target.value)}
                  >
                    <option value="">-- اختر المخزن --</option>
                    {warehouses
                      .filter(w => w.id !== currentWarehouseId)
                      .map(w => <option key={w.id} value={w.id}>{w.name}</option>)
                    }
                  </select>
                </div>

                <div>
                  <label className="block text-xs font-bold text-slate-500 mb-1">ملاحظات</label>
                  <textarea
                    rows="2"
                    className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl resize-none"
                    value={requestNotes}
                    onChange={e => setRequestNotes(e.target.value)}
                    placeholder="أي ملاحظات إضافية..."
                  />
                </div>

                <div className="flex gap-3 pt-4 border-t">
                  <button
                    onClick={handleCreateTransfer}
                    disabled={isSubmitting}
                    className="flex-1 bg-indigo-600 text-white py-3 rounded-xl font-bold hover:bg-indigo-700 disabled:opacity-50"
                  >
                    {isSubmitting ? <Loader2 className="animate-spin mx-auto" size={20} /> : 'إرسال الطلب'}
                  </button>
                  <button
                    onClick={() => { setShowAddModal(false); setSelectedProduct(null); setProductSearch(''); }}
                    className="flex-1 bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 py-3 rounded-xl font-bold hover:bg-slate-200"
                  >
                    إلغاء
                  </button>
                </div>
              </div>
            )}
          </div>
        </div>
      )}

      {/* Modal تأكيد الموافقة */}
      <ConfirmModal
        isOpen={showApproveModal}
        onClose={() => { setShowApproveModal(false); setSelectedTransfer(null); }}
        onConfirm={() => handleApprove(selectedTransfer)}
        title="تأكيد الموافقة"
        message={`هل أنت متأكد من الموافقة على تحويل ${selectedTransfer?.requestedQty} قطعة من ${selectedTransfer?.itemName} إلى ${warehouseMap[selectedTransfer?.toWarehouseId]}؟`}
        type="info"
        confirmText="موافقة"
      />

      {/* Modal رفض الطلب */}
      <ConfirmModal
        isOpen={showRejectModal}
        onClose={() => { setShowRejectModal(false); setSelectedTransfer(null); setRejectReason(''); }}
        onConfirm={handleReject}
        title="رفض طلب التحويل"
        message={
          <div className="space-y-3">
            <p>رفض طلب تحويل {selectedTransfer?.requestedQty} قطعة من {selectedTransfer?.itemName}</p>
            <textarea
              className="w-full border border-rose-200 p-3 rounded-xl focus:border-rose-500 outline-none"
              placeholder="سبب الرفض..."
              value={rejectReason}
              onChange={e => setRejectReason(e.target.value)}
              rows="3"
            />
          </div>
        }
        type="danger"
        confirmText="رفض"
      />

      {/* بطاقات الإحصائيات */}
      <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div className="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/30 dark:to-indigo-900/30 p-5 rounded-2xl border border-blue-100 dark:border-blue-800">
          <p className="text-xs text-blue-600 dark:text-blue-400 mb-1">قيد الانتظار</p>
          <p className="text-3xl font-black text-blue-700 dark:text-blue-300">{stats.pending}</p>
        </div>
        <div className="bg-gradient-to-br from-emerald-50 to-green-50 dark:from-emerald-900/30 dark:to-green-900/30 p-5 rounded-2xl border border-emerald-100 dark:border-emerald-800">
          <p className="text-xs text-emerald-600 dark:text-emerald-400 mb-1">تمت الموافقة</p>
          <p className="text-3xl font-black text-emerald-700 dark:text-emerald-300">{stats.approved}</p>
        </div>
        <div className="bg-gradient-to-br from-rose-50 to-red-50 dark:from-rose-900/30 dark:to-red-900/30 p-5 rounded-2xl border border-rose-100 dark:border-rose-800">
          <p className="text-xs text-rose-600 dark:text-rose-400 mb-1">مرفوض</p>
          <p className="text-3xl font-black text-rose-700 dark:text-rose-300">{stats.rejected}</p>
        </div>
        <div className="bg-gradient-to-br from-purple-50 to-violet-50 dark:from-purple-900/30 dark:to-violet-900/30 p-5 rounded-2xl border border-purple-100 dark:border-purple-800">
          <p className="text-xs text-purple-600 dark:text-purple-400 mb-1">إجمالي القطع</p>
          <p className="text-3xl font-black text-purple-700 dark:text-purple-300">{stats.totalItems}</p>
        </div>
      </div>

      {/* شريط البحث والتصفية */}
      <div className="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 overflow-hidden">
        <div className="p-4 border-b bg-slate-50 dark:bg-slate-900/50 flex flex-wrap gap-3 items-center">
          <div className="relative flex-1 min-w-[200px]">
            <Search size={16} className="absolute right-3 top-3 text-slate-400" />
            <input
              className="w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 pr-9 p-2.5 rounded-lg outline-none text-sm focus:border-indigo-500"
              placeholder="بحث باسم المنتج أو السيريال..."
              value={searchTerm}
              onChange={e => setSearchTerm(e.target.value)}
            />
          </div>

          <select
            className="border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-sm bg-white dark:bg-slate-900"
            value={statusFilter}
            onChange={e => setStatusFilter(e.target.value)}
          >
            <option value="all">كل الحالات</option>
            <option value="pending">قيد الانتظار</option>
            <option value="approved">تمت الموافقة</option>
            <option value="rejected">مرفوض</option>
          </select>

          <select
            className="border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-sm bg-white dark:bg-slate-900"
            value={warehouseFilter}
            onChange={e => setWarehouseFilter(e.target.value)}
          >
            <option value="all">كل المخازن</option>
            {uniqueWarehouses.map(w => (
              <option key={w} value={w}>{warehouseMap[w] || w}</option>
            ))}
          </select>

          <div className="flex gap-2">
            <input
              type="date"
              className="border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-sm bg-white dark:bg-slate-900"
              value={dateRange.from}
              onChange={e => setDateRange({...dateRange, from: e.target.value})}
            />
            <span className="self-center text-slate-400 text-sm">→</span>
            <input
              type="date"
              className="border border-slate-200 dark:border-slate-700 p-2.5 rounded-lg text-sm bg-white dark:bg-slate-900"
              value={dateRange.to}
              onChange={e => setDateRange({...dateRange, to: e.target.value})}
            />
          </div>

          <button
            onClick={() => setShowAddModal(true)}
            className="bg-indigo-600 text-white px-4 py-2.5 rounded-lg text-sm font-bold hover:bg-indigo-700 flex items-center gap-2"
          >
            <Plus size={16} /> طلب تحويل
          </button>
        </div>

        {/* جدول الطلبات المعلقة */}
        <div className="p-4">
          <h3 className="font-bold text-lg mb-4 flex items-center gap-2">
            <Clock className="text-amber-500" size={20} />
            الطلبات المعلقة ({pendingRequests.length})
          </h3>
          
          <div className="overflow-x-auto">
            <table className="w-full text-right text-sm">
              <thead className="bg-slate-50 dark:bg-slate-900/50 text-slate-500 font-bold text-xs border-b">
                <tr>
                  <th className="p-4">من مخزن</th>
                  <th className="p-4">إلى مخزن</th>
                  <th className="p-4">المنتج</th>
                  <th className="p-4 text-center">الكمية</th>
                  <th className="p-4">طلب بواسطة</th>
                  <th className="p-4">التاريخ</th>
                  <th className="p-4">ملاحظات</th>
                  <th className="p-4 text-center">الإجراءات</th>
                </tr>
              </thead>
              <tbody className="divide-y divide-slate-100 dark:divide-slate-700">
                {pendingRequests.length === 0 ? (
                  <tr>
                    <td colSpan="8" className="p-8 text-center text-slate-400">
                      لا توجد طلبات معلقة
                     </td>
                  </tr>
                ) : (
                  pendingRequests.map(req => (
                    <tr key={req.id} className="hover:bg-slate-50 dark:hover:bg-slate-900/50 transition-colors">
                      <td className="p-4 font-medium text-indigo-600">{warehouseMap[req.fromWarehouseId] || req.fromWarehouseId}</td>
                      <td className="p-4 font-medium text-indigo-600">{warehouseMap[req.toWarehouseId] || req.toWarehouseId}</td>
                      <td className="p-4">
                        <p className="font-bold">{req.itemName}</p>
                        <p className="text-[10px] font-mono text-slate-400">{req.serialNumber}</p>
                      </td>
                      <td className="p-4 text-center font-black text-lg">{req.requestedQty}</td>
                      <td className="p-4 text-xs">
                        <p className="font-bold text-slate-700">{req.requestedBy}</p>
                        <p className="text-[9px] text-slate-400 mt-1">{req.requestedByRole === 'warehouse_manager' ? 'مدير مخزن' : req.requestedByRole === 'sales' ? 'مبيعات' : req.requestedByRole}</p>
                      </td>
                      <td className="p-4 text-xs text-slate-500">{formatDate(req.createdAt)}</td>
                      <td className="p-4 text-xs text-slate-500 max-w-[150px] truncate">{req.notes || '-'}</td>
                      <td className="p-4 text-center">
                        {canApprove ? (
                          <div className="flex justify-center gap-2">
                            <button
                              onClick={() => { setSelectedTransfer(req); setShowApproveModal(true); }}
                              disabled={processingId === req.id}
                              className="p-1.5 bg-emerald-50 text-emerald-600 rounded-lg hover:bg-emerald-100"
                              title="موافقة"
                            >
                              <Check size={18} />
                            </button>
                            <button
                              onClick={() => { setSelectedTransfer(req); setShowRejectModal(true); }}
                              disabled={processingId === req.id}
                              className="p-1.5 bg-rose-50 text-rose-600 rounded-lg hover:bg-rose-100"
                              title="رفض"
                            >
                              <X size={18} />
                            </button>
                          </div>
                        ) : (
                          <span className="text-xs text-amber-600 flex items-center gap-1">
                            <Clock size={12} /> قيد الانتظار
                          </span>
                        )}
                        {user?.role === 'admin' && (
                          <button
                            onClick={() => handleDeleteTransfer(req)}
                            className="mt-1 text-[10px] text-slate-400 hover:text-rose-500"
                          >
                            حذف الطلب
                          </button>
                        )}
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>

        {/* جدول سجل التحويلات */}
        <div className="p-4 border-t border-slate-100 dark:border-slate-700">
          <h3 className="font-bold text-lg mb-4 flex items-center gap-2">
            <FileText className="text-indigo-500" size={20} />
            سجل التحويلات ({processedRequests.length})
          </h3>
          
          <div className="overflow-x-auto">
            <table className="w-full text-right text-sm">
              <thead className="bg-slate-50 dark:bg-slate-900/50 text-slate-500 font-bold text-xs border-b">
                <tr>
                  <th className="p-4">من مخزن</th>
                  <th className="p-4">إلى مخزن</th>
                  <th className="p-4">المنتج</th>
                  <th className="p-4 text-center">الكمية</th>
                  <th className="p-4">الحالة</th>
                  <th className="p-4">طلب بواسطة</th>
                  <th className="p-4">تاريخ الطلب</th>
                  <th className="p-4">تاريخ المعالجة</th>
                  <th className="p-4">معالج بواسطة</th>
                </tr>
              </thead>
              <tbody className="divide-y divide-slate-100 dark:divide-slate-700">
                {processedRequests.length === 0 ? (
                  <tr>
                    <td colSpan="9" className="p-8 text-center text-slate-400">
                      لا توجد تحويلات سابقة
                     </td>
                  </tr>
                ) : (
                  processedRequests.map(req => (
                    <tr key={req.id} className="hover:bg-slate-50 dark:hover:bg-slate-900/50 transition-colors">
                      <td className="p-4 font-medium text-indigo-600">{warehouseMap[req.fromWarehouseId] || req.fromWarehouseId}</td>
                      <td className="p-4 font-medium text-indigo-600">{warehouseMap[req.toWarehouseId] || req.toWarehouseId}</td>
                      <td className="p-4">
                        <p className="font-bold">{req.itemName}</p>
                        <p className="text-[10px] font-mono text-slate-400">{req.serialNumber}</p>
                      </td>
                      <td className="p-4 text-center font-black">{req.requestedQty}</td>
                      <td className="p-4">
                        {req.status === 'approved' ? (
                          <div>
                            <span className="inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 px-2 py-1 rounded-lg text-[10px] font-bold">
                              <Check size={12} /> تمت الموافقة
                            </span>
                          </div>
                        ) : (
                          <div>
                            <span className="inline-flex items-center gap-1 bg-rose-100 text-rose-700 px-2 py-1 rounded-lg text-[10px] font-bold">
                              <X size={12} /> مرفوض
                            </span>
                            {req.rejectReason && (
                              <p className="text-[9px] text-rose-600 mt-1 max-w-[150px]">{req.rejectReason}</p>
                            )}
                          </div>
                        )}
                      </td>
                      <td className="p-4 text-xs">
                        <p className="font-bold text-slate-700">{req.requestedBy}</p>
                        <p className="text-[9px] text-slate-400">{req.requestedByRole}</p>
                      </td>
                      <td className="p-4 text-xs text-slate-500">{formatDate(req.createdAt)}</td>
                      <td className="p-4 text-xs text-slate-500">{req.processedAt ? formatDate(req.processedAt) : '-'}</td>
                      <td className="p-4 text-xs">
                        {req.processedBy && (
                          <>
                            <p className="font-bold text-slate-700">{req.processedBy}</p>
                            <p className="text-[9px] text-slate-400">{req.processedByRole}</p>
                          </>
                        )}
                      </td>
                    </td>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  );
}