                value={ticketData.estimatedDuration}
                onChange={(e) => setTicketData({...ticketData, estimatedDuration: e.target.value})}
                className="w-full border border-slate-200 p-3 rounded-xl bg-white"
                placeholder="مثال: 3 أيام"
