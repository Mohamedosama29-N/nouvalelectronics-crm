import React, { useState, useEffect, useCallback } from 'react';
import { 
  X, Save, User, Phone, Smartphone, MapPin, Calendar, 
  AlertCircle, Clock, MessageSquare, Users, Wrench,
  Building, Send, Edit2, Trash2, Plus, Search, CheckCircle,
  FileText, ShoppingBag, RefreshCw, Box, Archive, Flag,
  Star, Award, Crown, Shield, CreditCard, Package, Truck,
  Loader2, Facebook, Instagram, Globe, Headphones as HeadphonesIcon,
  MessageCircle, Store, Landline
} from 'lucide-react';
import { useAuth } from '../../contexts/AuthContext';
import { useNotification } from '../../contexts/NotificationContext';
import { 
  collection, addDoc, getDocs, getDoc, updateDoc, doc, 
  query, where, serverTimestamp, writeBatch, increment 
} from 'firebase/firestore';
import { db } from '../../services/firebase';
import { EGYPT_GOVERNORATES } from '../../utils/constants';
import { formatDate, normalizeSearch, showSuccess, showError, showConfirm } from '../../utils/helpers';

// أنواع التذاكر
const TICKET_TYPES = [
  { value: 'complaint', label: 'شكوى', icon: AlertCircle, color: 'text-rose-500' },
  { value: 'inquiry', label: 'استفسار', icon: MessageSquare, color: 'text-blue-500' },
  { value: 'spare_parts', label: 'قطع غيار', icon: Package, color: 'text-amber-500' },
  { value: 'replacement', label: 'طلب استبدال', icon: RefreshCw, color: 'text-purple-500' },
  { value: 'purchase_request', label: 'طلب شراء', icon: ShoppingBag, color: 'text-emerald-500' },
  { value: 'after_sales', label: 'ما بعد البيع', icon: Archive, color: 'text-indigo-500' },
  { value: 'maintenance', label: 'صيانة', icon: Wrench, color: 'text-orange-500' }
];

// مصادر التذكرة
const SOURCES = [
  { value: 'hotline', label: 'خدمة العملاء (هوت لاين)', icon: HeadphonesIcon, color: 'text-slate-500' },
  { value: 'facebook', label: 'فيسبوك', icon: Facebook, color: 'text-blue-600' },
  { value: 'whatsapp', label: 'واتساب', icon: MessageCircle, color: 'text-green-600' },
  { value: 'friend', label: 'اقتراح صديق', icon: Users, color: 'text-purple-500' },
  { value: 'instagram', label: 'انستجرام', icon: Instagram, color: 'text-pink-500' },
  { value: 'website', label: 'الموقع الإلكتروني', icon: Globe, color: 'text-cyan-500' },
  { value: 'store', label: 'الفرع', icon: Store, color: 'text-indigo-500' }
];

// حالات الضمان
const WARRANTY_STATUS = [
  { value: 'in_warranty', label: 'داخل الضمان', color: 'text-emerald-500' },
  { value: 'out_of_warranty', label: 'خارج الضمان', color: 'text-rose-500' }
];

// الأولويات
const PRIORITIES = [
  { value: 'low', label: 'منخفضة', color: 'text-slate-500', bgColor: 'bg-slate-100' },
  { value: 'medium', label: 'متوسطة', color: 'text-blue-500', bgColor: 'bg-blue-100' },
  { value: 'high', label: 'عالية', color: 'text-rose-500', bgColor: 'bg-rose-100' },
  { value: 'urgent', label: 'طارئة', color: 'text-purple-500', bgColor: 'bg-purple-100' }
];

export function TicketModal({ isOpen, onClose, onSave, editingTicket, setGlobalLoading, notify }) {
  const { user } = useAuth();
  const [customers, setCustomers] = useState([]);
  const [searchCustomer, setSearchCustomer] = useState('');
  const [showCustomerSearch, setShowCustomerSearch] = useState(false);
  const [loading, setLoading] = useState(false);
  
  const [ticketData, setTicketData] = useState({
    customerId: '',
    customerName: '',
    customerPhone: '',
    customerPhone2: '',
    customerLandline: '',
    customerEmail: '',
    customerAddress: '',
    customerCity: '',
    customerGovernorate: '',
    nearestBranch: '',
    type: 'maintenance',
    source: 'hotline',
    priority: 'medium',
    warrantyStatus: 'in_warranty',
    deviceType: '',
    deviceModel: '',
    deviceSerial: '',
    subject: '',
    description: '',
    expectedCost: 0,
    estimatedDuration: '',
    assignedTechnician: '',
    assignedMaintenanceCenter: '',
    assignedCallCenter: '',
    preferredContact: 'phone',
    bestCallTime: '',
    comments: [],
    attachments: [],
    tags: []
  });
  
  const [newComment, setNewComment] = useState('');
  const [editingComment, setEditingComment] = useState(null);
  const [technicians, setTechnicians] = useState([]);
  const [maintenanceCenters, setMaintenanceCenters] = useState([]);
  const [callCenters, setCallCenters] = useState([]);
  const [branches, setBranches] = useState([]);

  // تحميل العملاء
  const loadCustomers = useCallback(async (searchTerm) => {
    if (!searchTerm || searchTerm.length < 2) {
      setCustomers([]);
      return;
    }
    
    setLoading(true);
    try {
      const customersRef = collection(db, 'customers');
      const q = query(customersRef);
      const snap = await getDocs(q);
      
      const filtered = snap.docs
        .map(d => ({ id: d.id, ...d.data() }))
        .filter(c => 
          c.name?.toLowerCase().includes(searchTerm.toLowerCase()) ||
          c.phone?.includes(searchTerm) ||
          c.email?.toLowerCase().includes(searchTerm.toLowerCase())
        )
        .slice(0, 10);
      
      setCustomers(filtered);
    } catch (error) {
      console.error('Error loading customers:', error);
    } finally {
      setLoading(false);
    }
  }, []);

  // تحميل الفروع
  const loadBranches = useCallback(async () => {
    try {
      const branchesRef = collection(db, 'branches');
      const snap = await getDocs(branchesRef);
      const branchesData = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      if (branchesData.length > 0) {
        setBranches(branchesData);
      } else {
        setBranches([
          { id: 'branch1', name: 'الفرع الرئيسي - القاهرة', address: 'مدينة نصر' },
          { id: 'branch2', name: 'فرع الإسكندرية', address: 'محطة الرمل' },
          { id: 'branch3', name: 'فرع الجيزة', address: 'المهندسين' },
          { id: 'branch4', name: 'فرع المنصورة', address: 'شارع الجيش' }
        ]);
      }
    } catch (error) {
      console.error('Error loading branches:', error);
    }
  }, []);

  // تحميل الموظفين
  const loadEmployees = useCallback(async () => {
    try {
      const techs = await getDocs(query(collection(db, 'employees'), where('role', '==', 'technician')));
      setTechnicians(techs.docs.map(d => ({ id: d.id, ...d.data() })));
      
      const centers = await getDocs(query(collection(db, 'employees'), where('role', '==', 'maintenance_center')));
      setMaintenanceCenters(centers.docs.map(d => ({ id: d.id, ...d.data() })));
      
      const calls = await getDocs(query(collection(db, 'employees'), where('role', '==', 'call_center')));
      setCallCenters(calls.docs.map(d => ({ id: d.id, ...d.data() })));
    } catch (error) {
      console.error('Error loading employees:', error);
    }
  }, []);

  useEffect(() => {
    if (isOpen) {
      loadBranches();
      loadEmployees();
    }
  }, [isOpen]);

  useEffect(() => {
    const debounce = setTimeout(() => {
      if (searchCustomer) {
        loadCustomers(searchCustomer);
      }
    }, 500);
    return () => clearTimeout(debounce);
  }, [searchCustomer, loadCustomers]);

  const handleSelectCustomer = (customer) => {
    setTicketData({
      ...ticketData,
      customerId: customer.id,
      customerName: customer.name || '',
      customerPhone: customer.phone || '',
      customerPhone2: customer.phone2 || '',
      customerLandline: customer.landline || '',
      customerEmail: customer.email || '',
      customerAddress: customer.address || '',
      customerCity: customer.city || '',
      customerGovernorate: customer.governorate || '',
      nearestBranch: customer.nearestBranch || '',
    });
    setShowCustomerSearch(false);
    setSearchCustomer('');
  };

  const handleAddComment = () => {
    if (!newComment.trim()) return;
    
    const comment = {
      id: Date.now().toString(),
      text: newComment,
      createdAt: new Date().toISOString(),
      createdBy: user?.name || 'System',
      createdById: user?.id
    };
    
    setTicketData({
      ...ticketData,
      comments: [...ticketData.comments, comment]
    });
    setNewComment('');
  };

  const handleEditComment = () => {
    if (!editingComment || !newComment.trim()) return;
    
    setTicketData({
      ...ticketData,
      comments: ticketData.comments.map(c => 
        c.id === editingComment.id 
          ? { ...c, text: newComment, editedAt: new Date().toISOString(), editedBy: user?.name }
          : c
      )
    });
    setEditingComment(null);
    setNewComment('');
  };

  const handleDeleteComment = (commentId) => {
    setTicketData({
      ...ticketData,
      comments: ticketData.comments.filter(c => c.id !== commentId)
    });
  };

  const startEditComment = (comment) => {
    setEditingComment(comment);
    setNewComment(comment.text);
  };

  const handleSave = async () => {
    if (!ticketData.customerName || !ticketData.customerPhone) {
      showError("الرجاء إدخال اسم العميل ورقم الهاتف");
      return;
    }
    
    setGlobalLoading?.(true);
    setLoading(true);
    
    try {
      const ticketNumber = 'TKT-' + Date.now().toString().slice(-8);
      const now = new Date();
      
      const newTicket = {
        ...ticketData,
        ticketNumber,
        status: 'created',
        createdAt: serverTimestamp(),
        createdDate: now.toISOString().split('T')[0],
        createdTime: now.toLocaleTimeString('ar-EG'),
        createdBy: user?.id,
        createdByName: user?.name,
        updatedAt: serverTimestamp(),
        statusHistory: [{
          status: 'created',
          timestamp: now.toISOString(),
          by: user?.name,
          notes: 'تم إنشاء التذكرة'
        }],
        history: [{
          action: 'إنشاء تذكرة',
          timestamp: now.toISOString(),
          by: user?.name
        }],
        totalCost: 0,
        spareParts: []
      };
      
      if (!ticketData.customerId) {
        const customerData = {
          name: ticketData.customerName,
          phone: ticketData.customerPhone,
          phone2: ticketData.customerPhone2,
          landline: ticketData.customerLandline,
          email: ticketData.customerEmail,
          address: ticketData.customerAddress,
          city: ticketData.customerCity,
          governorate: ticketData.customerGovernorate,
          nearestBranch: ticketData.nearestBranch,
          createdAt: serverTimestamp(),
          createdBy: user?.id,
          createdByName: user?.name,
          ticketsCount: 1,
          searchKey: normalizeSearch(`${ticketData.customerName} ${ticketData.customerPhone}`)
        };
        
        const customerRef = await addDoc(collection(db, 'customers'), customerData);
        newTicket.customerId = customerRef.id;
      } else {
        const customerRef = doc(db, 'customers', ticketData.customerId);
        await updateDoc(customerRef, { ticketsCount: increment(1) });
      }
      
      const docRef = await addDoc(collection(db, 'tickets'), newTicket);
      
      showSuccess("تم إنشاء التذكرة بنجاح");
      
      onSave?.({ id: docRef.id, ...newTicket });
      resetForm();
      onClose();
      
    } catch (error) {
      console.error("Error saving ticket:", error);
      showError("حدث خطأ أثناء حفظ التذكرة");
    } finally {
      setGlobalLoading?.(false);
      setLoading(false);
    }
  };

  const resetForm = () => {
    setTicketData({
      customerId: '',
      customerName: '',
      customerPhone: '',
      customerPhone2: '',
      customerLandline: '',
      customerEmail: '',
      customerAddress: '',
      customerCity: '',
      customerGovernorate: '',
      nearestBranch: '',
      type: 'maintenance',
      source: 'hotline',
      priority: 'medium',
      warrantyStatus: 'in_warranty',
      deviceType: '',
      deviceModel: '',
      deviceSerial: '',
      subject: '',
      description: '',
      expectedCost: 0,
      estimatedDuration: '',
      assignedTechnician: '',
      assignedMaintenanceCenter: '',
      assignedCallCenter: '',
      preferredContact: 'phone',
      bestCallTime: '',
      comments: [],
      attachments: [],
      tags: []
    });
    setSearchCustomer('');
    setNewComment('');
    setEditingComment(null);
  };

  if (!isOpen) return null;

  return (
    <div className="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
      <div className="bg-white dark:bg-slate-800 rounded-2xl w-full max-w-6xl max-h-[90vh] overflow-y-auto shadow-2xl">
        <div className="sticky top-0 bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 p-6 flex justify-between items-center">
          <div className="flex items-center gap-3">
            <div className="p-2 bg-indigo-100 dark:bg-indigo-900/30 rounded-xl">
              <MessageSquare className="text-indigo-600 dark:text-indigo-400" size={24} />
            </div>
            <h2 className="text-xl font-black text-slate-800 dark:text-white">
              {editingTicket ? 'تعديل تذكرة' : 'إنشاء تذكرة جديدة'}
            </h2>
          </div>
          <button onClick={onClose} className="p-2 hover:bg-slate-100 dark:hover:bg-slate-700 rounded-lg">
            <X size={20} />
          </button>
        </div>

        <div className="p-6 space-y-6">
          
          {/* قسم بحث العميل */}
          <div className="bg-indigo-50 dark:bg-indigo-900/30 p-5 rounded-xl border border-indigo-100 dark:border-indigo-800">
            <h3 className="font-bold text-indigo-800 dark:text-indigo-300 mb-4 flex items-center gap-2">
              <User size={18} /> بيانات العميل
              <button
                type="button"
                onClick={() => setShowCustomerSearch(!showCustomerSearch)}
                className="mr-3 text-xs text-indigo-600 hover:underline"
              >
                {showCustomerSearch ? 'إلغاء البحث' : 'بحث عن عميل'}
              </button>
            </h3>
            
            {showCustomerSearch && (
              <div className="mb-4">
                <div className="relative">
                  <Search className="absolute right-3 top-3 text-slate-400" size={18} />
                  <input
                    type="text"
                    placeholder="ابحث باسم العميل أو رقم الهاتف..."
                    value={searchCustomer}
                    onChange={(e) => setSearchCustomer(e.target.value)}
                    className="w-full border border-indigo-200 dark:border-indigo-700 pr-10 p-3 rounded-xl focus:border-indigo-500 outline-none bg-white dark:bg-slate-900"
                  />
                </div>
                {loading && <div className="mt-2 text-center"><Loader2 className="animate-spin text-indigo-500" size={24} /></div>}
                {customers.length > 0 && (
                  <div className="mt-2 border border-indigo-200 dark:border-indigo-700 rounded-xl max-h-48 overflow-y-auto">
                    {customers.map(customer => (
                      <button
                        key={customer.id}
                        onClick={() => handleSelectCustomer(customer)}
                        className="w-full p-3 text-right hover:bg-indigo-100 dark:hover:bg-indigo-900/50 transition-colors border-b last:border-0"
                      >
                        <p className="font-bold text-slate-800 dark:text-white">{customer.name}</p>
                        <p className="text-sm text-slate-500">{customer.phone}</p>
                      </button>
                    ))}
                  </div>
                )}
              </div>
            )}
            
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
              <div>
                <label className="block text-xs font-bold text-slate-500 mb-1">
                  اسم العميل <span className="text-rose-500">*</span>
                </label>
                <input
                  type="text"
                  value={ticketData.customerName}
                  onChange={(e) => setTicketData({...ticketData, customerName: e.target.value})}
                  className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl focus:border-indigo-500 outline-none bg-white dark:bg-slate-900"
                />
              </div>
              <div>
                <label className="block text-xs font-bold text-slate-500 mb-1">
                  رقم الجوال <span className="text-rose-500">*</span>
                </label>
                <div className="relative">
                  <Phone className="absolute right-3 top-3 text-slate-400" size={16} />
                  <input
                    type="tel"
                    value={ticketData.customerPhone}
                    onChange={(e) => setTicketData({...ticketData, customerPhone: e.target.value})}
                    className="w-full border border-slate-200 dark:border-slate-700 pr-10 p-3 rounded-xl bg-white dark:bg-slate-900"
                    dir="ltr"
                  />
                </div>
              </div>
              <div>
                <label className="block text-xs font-bold text-slate-500 mb-1">جوال آخر</label>
                <div className="relative">
                  <Smartphone className="absolute right-3 top-3 text-slate-400" size={16} />
                  <input
                    type="tel"
                    value={ticketData.customerPhone2}
                    onChange={(e) => setTicketData({...ticketData, customerPhone2: e.target.value})}
                    className="w-full border border-slate-200 dark:border-slate-700 pr-10 p-3 rounded-xl bg-white dark:bg-slate-900"
                    dir="ltr"
                  />
                </div>
              </div>
              <div>
                <label className="block text-xs font-bold text-slate-500 mb-1">تليفون أرضي</label>
                <div className="relative">
                  <Landline className="absolute right-3 top-3 text-slate-400" size={16} />
                  <input
                    type="tel"
                    value={ticketData.customerLandline}
                    onChange={(e) => setTicketData({...ticketData, customerLandline: e.target.value})}
                    className="w-full border border-slate-200 dark:border-slate-700 pr-10 p-3 rounded-xl bg-white dark:bg-slate-900"
                    dir="ltr"
                  />
                </div>
              </div>
            </div>
            
            <div className="grid grid-cols-1 md:grid-cols-3 gap-4 mt-4">
              <div>
                <label className="block text-xs font-bold text-slate-500 mb-1">البريد الإلكتروني</label>
                <input
                  type="email"
                  value={ticketData.customerEmail}
                  onChange={(e) => setTicketData({...ticketData, customerEmail: e.target.value})}
                  className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl bg-white dark:bg-slate-900"
                />
              </div>
              <div>
                <label className="block text-xs font-bold text-slate-500 mb-1">المحافظة</label>
                <select
                  value={ticketData.customerGovernorate}
                  onChange={(e) => setTicketData({...ticketData, customerGovernorate: e.target.value})}
                  className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl bg-white dark:bg-slate-900"
                >
                  <option value="">اختر المحافظة</option>
                  {EGYPT_GOVERNORATES.map(gov => <option key={gov} value={gov}>{gov}</option>)}
                </select>
              </div>
              <div>
                <label className="block text-xs font-bold text-slate-500 mb-1">أقرب فرع</label>
                <select
                  value={ticketData.nearestBranch}
                  onChange={(e) => setTicketData({...ticketData, nearestBranch: e.target.value})}
                  className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl bg-white dark:bg-slate-900"
                >
                  <option value="">اختر أقرب فرع</option>
                  {branches.map(branch => <option key={branch.id} value={branch.name}>{branch.name}</option>)}
                </select>
              </div>
            </div>
            
            <div className="mt-4">
              <label className="block text-xs font-bold text-slate-500 mb-1">العنوان</label>
              <textarea
                rows="2"
                value={ticketData.customerAddress}
                onChange={(e) => setTicketData({...ticketData, customerAddress: e.target.value})}
                className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl bg-white dark:bg-slate-900 resize-none"
              />
            </div>
          </div>
          
          {/* قسم معلومات التذكرة */}
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 p-5 bg-slate-50 dark:bg-slate-900/50 rounded-xl">
            <div>
              <label className="block text-xs font-bold text-slate-500 mb-1">نوع التذكرة</label>
              <select
                value={ticketData.type}
                onChange={(e) => setTicketData({...ticketData, type: e.target.value})}
                className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl bg-white dark:bg-slate-900"
              >
                {TICKET_TYPES.map(type => <option key={type.value} value={type.value}>{type.label}</option>)}
              </select>
            </div>
            <div>
              <label className="block text-xs font-bold text-slate-500 mb-1">المصدر</label>
              <select
                value={ticketData.source}
                onChange={(e) => setTicketData({...ticketData, source: e.target.value})}
                className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl bg-white dark:bg-slate-900"
              >
                {SOURCES.map(source => <option key={source.value} value={source.value}>{source.label}</option>)}
              </select>
            </div>
            <div>
              <label className="block text-xs font-bold text-slate-500 mb-1">الأولوية</label>
              <select
                value={ticketData.priority}
                onChange={(e) => setTicketData({...ticketData, priority: e.target.value})}
                className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl bg-white dark:bg-slate-900"
              >
                {PRIORITIES.map(p => <option key={p.value} value={p.value}>{p.label}</option>)}
              </select>
            </div>
            <div>
              <label className="block text-xs font-bold text-slate-500 mb-1">حالة الضمان</label>
              <select
                value={ticketData.warrantyStatus}
                onChange={(e) => setTicketData({...ticketData, warrantyStatus: e.target.value})}
                className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl bg-white dark:bg-slate-900"
              >
                {WARRANTY_STATUS.map(s => <option key={s.value} value={s.value}>{s.label}</option>)}
              </select>
            </div>
          </div>
          
          {/* قسم معلومات الجهاز */}
          <div className="bg-slate-50 dark:bg-slate-900/50 p-5 rounded-xl">
            <h3 className="font-bold text-slate-700 mb-4 flex items-center gap-2"><Wrench size={18} /> معلومات الجهاز</h3>
            <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label className="block text-xs font-bold text-slate-500 mb-1">نوع الجهاز</label>
                <input
                  value={ticketData.deviceType}
                  onChange={(e) => setTicketData({...ticketData, deviceType: e.target.value})}
                  className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl bg-white dark:bg-slate-900"
                />
              </div>
              <div>
                <label className="block text-xs font-bold text-slate-500 mb-1">الموديل</label>
                <input
                  value={ticketData.deviceModel}
                  onChange={(e) => setTicketData({...ticketData, deviceModel: e.target.value})}
                  className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl bg-white dark:bg-slate-900"
                />
              </div>
              <div>
                <label className="block text-xs font-bold text-slate-500 mb-1">السيريال</label>
                <input
                  value={ticketData.deviceSerial}
                  onChange={(e) => setTicketData({...ticketData, deviceSerial: e.target.value})}
                  className="w-full border border-slate-200 dark:border-slate-700 p-3 rounded-xl bg-white dark:bg-slate-900 font-mono"
                />
              </div>
            </div>
